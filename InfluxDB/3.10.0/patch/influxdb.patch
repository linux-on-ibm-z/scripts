+fn local_python_wasm_override() -> Option<PathBuf> {
+    println!("cargo::rerun-if-env-changed={LOCAL_PYTHON_WASM_ENV}");
+
+    if let Some(path) = std::env::var_os(LOCAL_PYTHON_WASM_ENV) {
+        let path = PathBuf::from(path);
+        assert!(
+            path.is_file(),
+            "{LOCAL_PYTHON_WASM_ENV} points to a non-existent file: {}",
+            path.display()
+        );
+        return Some(path);
+    }
+
+    let default_path = PathBuf::from(DEFAULT_LOCAL_PYTHON_WASM_PATH);
+    if default_path.is_file() {
+        return Some(default_path);
+    }
