+/// Convert native-endian statistic bytes to little-endian for Parquet wire format.
+/// On big-endian platforms, numeric types have their bytes reversed; byte arrays
+/// and booleans are unchanged. Only compiled on big-endian targets.
+#[cfg(target_endian = "big")]
+pub(crate) fn stat_bytes_to_le(bytes: &[u8], physical_type: Type) -> Vec<u8> {
+    match physical_type {
+        Type::INT32 | Type::FLOAT if bytes.len() >= 4 => {
+            let mut le = bytes[..4].to_vec();
+            le.reverse();
+            le
+        }
+        Type::INT64 | Type::DOUBLE if bytes.len() >= 8 => {
+            let mut le = bytes[..8].to_vec();
+            le.reverse();
+            le
+        }
+        Type::INT96 if bytes.len() >= 12 => {
+            // Int96 is 3 x u32, each component needs individual byte swap
+            let mut le = Vec::with_capacity(12);
+            for chunk in bytes[..12].chunks_exact(4) {
+                let mut c = chunk.to_vec();
+                c.reverse();
+                le.extend_from_slice(&c);
+            }
+            le
+        }
+        // BOOLEAN (1 byte), BYTE_ARRAY, FIXED_LEN_BYTE_ARRAY: no swap needed
+        _ => bytes.to_vec(),
+    }
+}
