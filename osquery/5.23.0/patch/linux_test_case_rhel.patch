+static std::string canonicalizePathForExclusion(const std::string& path) {
+  if (path.empty()) {
+    return path;
+  }
+
+  boost::system::error_code ec;
+  auto canonical_path = fs::canonical(path, ec);
+  if (ec) {
+    return path;
+  }
+
+  auto result = canonical_path.make_preferred().string();
+  if (!result.empty() && isDirectory(canonical_path).ok() &&
+      result.back() != '/') {
+    result += '/';
+  }
+  return result;
+}
+
+static bool isPathExcluded(const ExcludePathSet& exclude_paths,
+                           const std::string& path) {
+  if (path.empty()) {
+    return false;
+  }
+
+  if (exclude_paths.find(path)) {
+    return true;
+  }
+
+  const auto canonical_path = canonicalizePathForExclusion(path);
+  return canonical_path != path && exclude_paths.find(canonical_path);
+}
