diff --git a/openssl-dynamic/src/main/c/boringssl_compat.h b/openssl-dynamic/src/main/c/boringssl_compat.h
new file mode 100644
index 0000000..bb1e34a
--- /dev/null
+++ b/openssl-dynamic/src/main/c/boringssl_compat.h
@@ -0,0 +1,24 @@
+#ifndef NETTY_TCNATIVE_BORINGSSL_COMPAT_H
+#define NETTY_TCNATIVE_BORINGSSL_COMPAT_H
+
+#include <openssl/ssl.h>
+#include <openssl/x509.h>
+#include <stdint.h>
+#include <stddef.h>
+
+/*
+ * Compatibility shim for older BoringSSL headers.
+ *
+ * NOTE: Do NOT define SSL_CREDENTIAL_* functions here.
+ * netty-tcnative declares these APIs as weak externs in ssl_private.h.
+ * Defining them (even as static inline) causes symbol/type conflicts.
+ */
+
+#ifndef SSL_CREDENTIAL
+typedef struct ssl_credential_st {
+    int unused;
+} SSL_CREDENTIAL;
+#endif
+
+#endif /* NETTY_TCNATIVE_BORINGSSL_COMPAT_H */
+
